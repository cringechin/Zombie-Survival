{
  "name": "Zombie Survival",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$path": "src/ReplicatedStorage",
      "Assets": {
        "$className": "Folder",
        "Bosses": {
          "$className": "Folder",
          "LightningBoss": {
            "$className": "Folder",
            "LightningBossZombie": {
              "$className": "Model"
            }
          }
        },
        "VFX": {
          "$className": "Folder",
          "Bosses": {
            "$className": "Folder",
            "LightningVFX": {
              "$className": "Model"
            }
          },
          "Disasters": {
            "$className": "Folder",
            "Meteor": {
              "$className": "Folder"
            }
          }
        },
        "Zombies": {
          "$className": "Folder",
          "BasicZombie": {
            "$className": "Folder",
            "Zombie": {
              "$className": "Model"
            }
          },
          "Sprinter": {
            "$className": "Folder",
            "Zombie": {
              "$className": "Model"
            }
          },
          "Tank": {
            "$className": "Folder",
            "Zombie": {
              "$className": "Model"
            }
          }
        }
      },
      "Packages": {
        "$path": "Packages"
      }
    },
    "ServerScriptService": {
      "$path": "src/ServerScriptService",
      "ServerPackages": {
        "$path": "ServerPackages"
      }
    },
    "ServerStorage": {
      "WeaponTemplates": {
        "$className": "Folder",
        "Meteor": {
          "$className": "Tool",
          "$properties": {
            "RequiresHandle": false,
            "CanBeDropped": false,
            "ToolTip": "Launch a meteor"
          },
          "MeteorClient": {
            "$path": "src/StarterPack/Meteor/Meteor.client.lua"
          }
        }
      }
    },
    "StarterPlayer": {
      "$properties": {
        "EnableMouseLockOption": true
      },
      "StarterPlayerScripts": {
        "$path": "src/StarterPlayer/StarterPlayerScripts"
      }
    },
    "StarterPack": {
      "Lightning": {
        "$className": "Tool",
        "$properties": {
          "RequiresHandle": false,
          "CanBeDropped": false,
          "ToolTip": "Call down lightning"
        },
        "LightningClient": {
          "$path": "src/StarterPack/Lightning/Lightning.client.lua"
        }
      }
    },
    "Workspace": {
      "Arena": {
        "$className": "Folder"
      },
      "Zombies": {
        "$className": "Folder"
      },
      "ZombieSpawns": {
        "$className": "Folder"
      }
    }
  }
}
