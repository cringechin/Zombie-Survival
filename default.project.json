            }
          },
          "Sprinter": {
            "$className": "Folder",
            "Zombie": {
              "$className": "Model"
            }
          },
          "Tank": {
            "$className": "Folder",
            "Zombie": {
              "$className": "Model"
            }
          }
        }
      },
      "Packages": {
        "$path": "Packages"
      }
    },
    "ServerScriptService": {
      "$path": "src/ServerScriptService",
      "ServerPackages": {
        "$path": "ServerPackages"
      }
    },
    "StarterPlayer": {
