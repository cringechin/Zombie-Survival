{
  "name": "Zombie Survival",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$path": "src/ReplicatedStorage",
      "Assets": {
        "$className": "Folder",
        "Zombies": {
          "$className": "Folder",
          "BasicZombie": {
            "$className": "Folder",
